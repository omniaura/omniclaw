# Network discovery
# Set to true to allow discovery admin actions from loopback/private LAN
# without WEB_UI_USER/WEB_UI_PASS. Also permits WEB_UI_HOST=0.0.0.0
# without Basic Auth so peers can reach discovery endpoints. Only use this
# on a trusted private LAN.
DISCOVERY_TRUST_LAN_ADMIN=false

# Firebase (for agents needing Firebase access)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Google Cloud
# GOOGLE_APPLICATION_CREDENTIALS=
# GCLOUD_PROJECT=

# Split-execution: run agent runtime and heavy workloads (builds, browsers, tests)
# in separate containers. The agent gets a bash shim that proxies commands to an
# execution sidecar via docker exec. Prevents builds/browsers from OOM-killing the agent.
# Requires Docker (not Apple Container). Both containers share the same workspace mount.
# SPLIT_EXECUTION=false
# EXEC_CONTAINER_MEMORY=8G
